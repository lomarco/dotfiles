### Variables
set $mod Mod4

set $left h
set $down j
set $up k
set $right l

set $term "foot -e tmux new-session -A -s base"
set $browser "waterfox"
set $menu "wmenu-run"
set $zathura "zathura"
set $telegram "AyuGram"
set $colorpicker "hyprpicker -a"
set $zoom "woomer"
set $locker "swaylock -f -c 000000"

set $global_font "IosevkaTermNerdFont 10"
font $global_font


### Output configuration
output * bg #000000 solid_color


### Input configuration
input type:touchpad {
  dwt enabled
  tap enabled
  natural_scroll enabled
  middle_emulation enabled
}

input type:keyboard {
  xkb_layout us,ru
  xkb_options grp:alt_shift_toggle
  repeat_rate 60
  repeat_delay 200
}


### Key bindings
# Basics:
bindsym $mod+y exec bash -c 'pid=$(pgrep wf-recorder); if [ -n "$pid" ]; then kill -SIGINT $pid && notify-send -u normal -t 3000 -a "wf-recorder" "Screen recording stopped and saved"; else geo=$(slurp 2>/dev/null) && [ -n "$geo" ] && { notify-send -u normal -t 3000 -a "wf-recorder" "Recording region started"; wf-recorder -g "$geo" -f "$HOME/rec_$(date +%Y%m%d_%H%M%S).mkv" 2>/tmp/wfrec.err &> /dev/null; } || { notify-send -u critical -t 3000 -a "wf-recorder" "Selection cancelled or wf-recorder failed"; cat /tmp/wfrec.err | grep -v "libstrangle" 2>/dev/null; }; fi'
bindsym $mod+g exec $locker
bindsym $mod+n exec 'cliphist list | wmenu -p "ClipBoard:" -l 10 -b | { read -r line && echo "$line" | cliphist decode | wl-copy; }'
bindsym $mod+c exec bash -c 'tmp=$(mktemp "$HOME/screenshot-XXXXXX.png") || tmp=""; if [ -z "$tmp" ]; then fallback="$HOME/fallback-slurp-$(date +%Y%m%d-%H%M%S).png"; grim > "$fallback" 2>/dev/null || { notify-send -u critical -t 5000 "Screenshot" "Failed to take screenshot"; exit 1; }; wl-copy < "$fallback" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved fallback image"; exit 0; fi; notify-send -u low -t 1500 "Screenshot" "Select region..."; region=$(slurp) || { rm -f -- "$tmp" 2>/dev/null || true; notify-send -u low -t 1500 "Screenshot" "Selection cancelled"; exit 0; }; if ! grim -g "$region" "$tmp" 2>/dev/null; then rm -f -- "$tmp" 2>/dev/null || true; fallback="$HOME/fallback-slurp-$(date +%Y%m%d-%H%M%S).png"; grim > "$fallback" 2>/dev/null || { notify-send -u critical -t 5000 "Screenshot" "Failed to save screenshot"; exit 1; }; wl-copy < "$fallback" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved fallback image"; exit 0; fi; notify-send -u normal -t 2000 "Screenshot" "Region captured"; new=$(printf "%s" "$tmp" | wmenu -i -p "Save as (edit) or Enter to keep:"); rc=$?; if [ $rc -eq 0 ]; then dest="$HOME/screenshot-$(date +%Y%m%d-%H%M%S).png"; if [ -n "$new" ] && [ "$new" != "$tmp" ]; then if mv -- "$tmp" "$new" 2>/dev/null; then wl-copy < "$new" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved as $(basename "$new")"; else fallback="$HOME/fallback-slurp-$(date +%Y%m%d-%H%M%S).png"; mv -- "$tmp" "$fallback" 2>/dev/null || cp -- "$tmp" "$fallback" 2>/dev/null || true; wl-copy < "$fallback" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved fallback image"; fi; else if mv -- "$tmp" "$dest" 2>/dev/null; then wl-copy < "$dest" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved as $(basename "$dest")"; else fallback="$HOME/fallback-slurp-$(date +%Y%m%d-%H%M%S).png"; mv -- "$tmp" "$fallback" 2>/dev/null || cp -- "$tmp" "$fallback" 2>/dev/null || true; wl-copy < "$fallback" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved fallback image"; fi; fi; else rm -f -- "$tmp" 2>/dev/null || true; notify-send -u low -t 1500 "Screenshot" "Cancelled"; fi'
bindsym $mod+Return exec $term
bindsym $mod+d exec $menu
bindsym $mod+Shift+b exec $browser
bindsym $mod+Shift+z exec $zathura
bindsym $mod+Shift+t exec $telegram
bindsym $mod+p exec $colorpicker
bindsym $mod+o exec $zoom

bindsym $mod+Shift+q kill
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaymsg exit

floating_modifier $mod normal


# Moving around:
default_border pixel 1
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right

bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right


# Workspaces:
bindsym $mod+m workspace m
bindsym $mod+u workspace u
bindsym $mod+i workspace i

bindsym $mod+Shift+m move container to workspace m
bindsym $mod+Shift+u move container to workspace u
bindsym $mod+Shift+i move container to workspace i


# Layout stuff:
bindsym $mod+b splith
bindsym $mod+v splitv

bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent


# Scratchpad:
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show


# Resizing containers:
mode "resize" {
  bindsym $left resize shrink width 10px
  bindsym $down resize grow height 10px
  bindsym $up resize shrink height 10px
  bindsym $right resize grow width 10px
  bindsym Return mode "default"
  bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"


# Utilities:
bindsym --locked XF86AudioMute exec pactl set-sink-mute \@DEFAULT_SINK@ toggle
bindsym --locked XF86AudioLowerVolume exec pactl set-sink-volume \@DEFAULT_SINK@ -5%
bindsym --locked XF86AudioRaiseVolume exec pactl set-sink-volume \@DEFAULT_SINK@ +5%
bindsym --locked XF86AudioMicMute exec pactl set-source-mute \@DEFAULT_SOURCE@ toggle
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-
bindsym --locked XF86MonBrightnessUp exec brightnessctl set 5%+
bindsym Print exec bash -c 'tmp=$(mktemp "$HOME/screenshot-XXXXXX.png") || tmp=""; if [ -z "$tmp" ]; then fallback="$HOME/fallback-full-$(date +%Y%m%d-%H%M%S).png"; grim > "$fallback" 2>/dev/null || { notify-send -u critical -t 5000 "Screenshot" "Failed to take full-screen screenshot"; exit 1; }; wl-copy < "$fallback" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved fallback image"; exit 0; fi; notify-send -u low -t 1500 "Screenshot" "Capturing full screen..."; if ! grim "$tmp" 2>/dev/null; then rm -f -- "$tmp" 2>/dev/null || true; fallback="$HOME/fallback-full-$(date +%Y%m%d-%H%M%S).png"; grim > "$fallback" 2>/dev/null || { notify-send -u critical -t 5000 "Screenshot" "Failed to save full-screen screenshot"; exit 1; }; wl-copy < "$fallback" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved fallback image"; exit 0; fi; notify-send -u normal -t 2000 "Screenshot" "Full screen captured"; new=$(printf "%s" "$tmp" | wmenu -i -p "Full screen. Edit or press Enter to keep:"); rc=$?; if [ $rc -eq 0 ]; then dest="$HOME/screenshot-$(date +%Y%m%d-%H%M%S).png"; if [ -n "$new" ] && [ "$new" != "$tmp" ]; then if mv -- "$tmp" "$new" 2>/dev/null; then wl-copy < "$new" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved as $(basename "$new")"; else fallback="$HOME/fallback-full-$(date +%Y%m%d-%H%M%S).png"; mv -- "$tmp" "$fallback" 2>/dev/null || cp -- "$tmp" "$fallback" 2>/dev/null || true; wl-copy < "$fallback" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved fallback image"; fi; else if mv -- "$tmp" "$dest" 2>/dev/null; then wl-copy < "$dest" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved as $(basename "$dest")"; else fallback="$HOME/fallback-full-$(date +%Y%m%d-%H%M%S).png"; mv -- "$tmp" "$fallback" 2>/dev/null || cp -- "$tmp" "$fallback" 2>/dev/null || true; wl-copy < "$fallback" 2>/dev/null || true; notify-send -u normal -t 3000 "Screenshot" "Saved fallback image"; fi; fi; else rm -f -- "$tmp" 2>/dev/null || true; notify-send -u low -t 1500 "Screenshot" "Cancelled"; fi'

# Status Bar:
bar {
  position bottom
  status_command i3status-rs
  font $global_font
  tray_output *
}


### Demons
exec --no-startup-id swayidle -w \
  timeout 180 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
  timeout 240 '$locker' before-sleep '$locker'
exec --no-startup-id wlsunset -t 2600 -T 3000
exec --no-startup-id wl-paste --watch cliphist store
exec --no-startup-id fnott
