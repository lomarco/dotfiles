#!/bin/bash

[[ $EUID -ne 0 ]] && echo -e "\033[0;31mThis script must be run as root\033[0m" && exit 1

LEDS_DIR=/sys/devices
declare -A orig

restore() {
  for f in "${!orig[@]}"; do echo "${orig[$f]}" > "$f"; done
  exit
}

trap restore SIGINT SIGTERM

mapfile -t files < <(find "$LEDS_DIR" -name brightness -type f -writable 2>/dev/null)

[[ ${#files[@]} -eq 0 ]] && exit 1

for f in "${files[@]}"; do orig["$f"]=$(cat "$f" 2>/dev/null); done

while :; do
  for f in "${files[@]}"; do echo 1 > "$f" 2>/dev/null; sleep 0.1; done
  for f in "${files[@]}"; do echo 0 > "$f" 2>/dev/null; sleep 0.1; done
done
