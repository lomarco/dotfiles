#!/bin/sh

[[ $EUID -ne 0 ]] && echo -e "\033[0;31mThis script must be run as root\033[0m" && exit 1

LEDS_DIR="/sys/class/leds"
LED_FILE="brightness"
MAX_NUM_FILE="max_brightness"
declare -A orig
files=()

restore() {
  for f in "${!orig[@]}"; do
    echo "${orig[$f]}" > "$f"
  done
  exit
}

trap restore SIGINT SIGTERM

for led in "$LEDS_DIR"/*; do
  f="$led/$LED_FILE"
  maxf="$led/$MAX_NUM_FILE"
  [[ -f "$f" && -w "$f" && -r "$maxf" ]] || continue

  max_brightness=$(cat "$maxf")
  files+=("$f|$max_brightness")
done

[[ ${#files[@]} -eq 0 ]] && exit 1

for entry in "${files[@]}"; do
  f=$(echo "$entry" | cut -d'|' -f1)
  orig["$f"]=$(<"$f")
done

while :; do
  for entry in "${files[@]}"; do
    f=$(echo "$entry" | cut -d'|' -f1)
    max_brightness=$(echo "$entry" | cut -d'|' -f2)
    echo "$max_brightness" > "$f"
    sleep 0.1
  done
  for f in "${files[@]}"; do
    f=$(echo "$f" | cut -d'|' -f1)
    echo 0 > "$f"
    sleep 0.1
  done
done
